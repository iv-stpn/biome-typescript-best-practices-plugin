{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "plugins": ["./node_modules/biome-one-liner-plugin/oneLiner.grit"],
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 130
  },
  "linter": {
    "rules": {
      "preset": "recommended"
    }
  },
  "files": {
    "includes": [
      "**/*.js",
      "**/*.jsx",
      "**/*.ts",
      "**/*.tsx",
      "**/*.mjs",
      "**/*.cjs",
      "**/*.json",
      "**/*.md",
      "!example.ts",
      "!tests",
      "!scratch",
      "!node_modules"
    ]
  }
}
